diff --git a/.cursor/rules/design/structure.mdc b/.cursor/rules/design/structure.mdc
new file mode 100644
index 0000000..bc40c79
--- /dev/null
+++ b/.cursor/rules/design/structure.mdc
@@ -0,0 +1,22 @@
+---
+description: 
+globs: 
+alwaysApply: false
+---
+The code’s structure will be as such:
+/src
+  /components
+    Wrapper.jsx         - Top-level layout component with global styling (font, padding,
+centering)
+    Header.jsx          - Contains heading and circular profile image
+    Bio.jsx	        - Contains bio
+    Contact.jsx         - Horizontal rule, contact section with icons and links
+  /styles
+    globals.css         - Tailwind base styles and Plus Jakarta Sans font import
+    tailwind.config.js  - Tailwind configuration (extend if needed)
+
+App.jsx                 - Main entry point that assembles all components
+
+/public
+  profile.jpg           - Provided square image to be shown as circular logo
+  index.html            - Root HTML file
\ No newline at end of file


