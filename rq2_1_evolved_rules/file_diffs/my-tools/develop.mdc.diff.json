    "id": "E35_58",
    "change_type": "added",
    "content": "### useTheme Hook 设计规范\n```typescript\n// ✅ 正确的Hook设计\nexport function useTheme() {\n  const [theme, setTheme] = useState<ThemeMode>('system');\n  const [isDark, setIsDark] = useState(false);\n\n  // 初始化主题\n  useEffect(() => {\n    initializeTheme();\n  }, []); // 只在组件挂载时执行\n\n  // 监听系统主题变化\n  useEffect(() => {\n    if (theme === 'system') {\n      const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');\n      const handleChange = (e: MediaQueryListEvent) => {\n        setIsDark(e.matches);\n        applyTheme(e.matches ? 'dark' : 'light');\n      };\n      \n      mediaQuery.addEventListener('change', handleChange);\n      return () => mediaQuery.removeEventListener('change', handleChange);\n    }\n  }, [theme]); // 只依赖theme变化\n\n  return { theme, isDark, changeTheme };\n}\n```",
    "project": "my-tools",
    "file": ".cursor/rules/develop.mdc",
    "commit_id": "7eeed940ba4c8eb345dba4656b65805cce7ddd2a",
    "first_level": "Code Implementation",
    "second_level": "Framework Usage",
    "constraint_degree": "Recommended"
  },
