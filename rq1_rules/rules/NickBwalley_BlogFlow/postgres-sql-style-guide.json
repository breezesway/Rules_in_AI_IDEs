    "file": "postgres-sql-style-guide.mdc",
    "first_level": "Code Implementation",
    "second_level": "Code Style Conventions"
  },
  {
    "id": "R57_109",
    "content": "Prefer singular names for columns.",
    "project": "NickBwalley_BlogFlow",
    "file": "postgres-sql-style-guide.mdc",
    "first_level": "Code Implementation",
    "second_level": "Code Style Conventions"
  },
  {
    "id": "R57_110",
    "content": "Avoid prefixes like 'tbl\\_' and ensure no table name matches any of its column names.",
    "project": "NickBwalley_BlogFlow",
    "file": "postgres-sql-style-guide.mdc",
    "first_level": "Code Implementation",
    "second_level": "Code Style Conventions"
  },
  {
    "id": "R57_111",
    "content": "Always add an `id` column of type `identity generated always` unless otherwise specified.",
