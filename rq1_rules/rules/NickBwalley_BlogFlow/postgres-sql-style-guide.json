    "file": "postgres-sql-style-guide.mdc",
    "first_level": "Architecture & Design",
    "second_level": "Design Principles & Patterns"
  },
  {
    "id": "R57_112",
    "content": "Create all tables in the `public` schema unless otherwise specified.",
    "project": "NickBwalley_BlogFlow",
    "file": "postgres-sql-style-guide.mdc",
    "first_level": "Architecture & Design",
    "second_level": "System Architecture"
  },
  {
    "id": "R57_113",
    "content": "Always add the schema to SQL queries for clarity.",
    "project": "NickBwalley_BlogFlow",
    "file": "postgres-sql-style-guide.mdc",
    "first_level": "Code Implementation",
    "second_level": "Language Features"
  },
  {
    "id": "R57_114",
    "content": "Always add a comment to describe what the table does. The comment can be up to 1024 characters.",
    "project": "NickBwalley_BlogFlow",
    "file": "postgres-sql-style-guide.mdc",
    "first_level": "Code Implementation",
    "second_level": "Code Style Conventions"
  },
  {
    "id": "R57_115",
    "content": "Use singular names and avoid generic names like 'id'.",
    "project": "NickBwalley_BlogFlow",
    "file": "postgres-sql-style-guide.mdc",
    "first_level": "Code Implementation",
    "second_level": "Code Style Conventions"
  },
  {
    "id": "R57_116",
    "content": "For references to foreign tables, use the singular of the table name with the `_id` suffix. For example `user_id` to reference the `users` table.",
    "project": "NickBwalley_BlogFlow",
    "file": "postgres-sql-style-guide.mdc",
    "first_level": "Code Implementation",
    "second_level": "Code Style Conventions"
  },
  {
    "id": "R57_117",
    "content": "Always use lowercase except in cases involving acronyms or when readability would be enhanced by an exception.",
    "project": "NickBwalley_BlogFlow",
    "file": "postgres-sql-style-guide.mdc",
    "first_level": "Code Implementation",
    "second_level": "Code Style Conventions"
  },
  {
    "id": "R57_118",
    "content": "When the query is shorter keep it on just a few lines. As it gets larger start adding newlines for readability.",
    "project": "NickBwalley_BlogFlow",
    "file": "postgres-sql-style-guide.mdc",
    "first_level": "Code Implementation",
    "second_level": "Code Style Conventions"
  },
  {
    "id": "R57_119",
    "content": "Add spaces for readability.",
    "project": "NickBwalley_BlogFlow",
    "file": "postgres-sql-style-guide.mdc",
    "first_level": "Code Implementation",
    "second_level": "Code Style Conventions"
  },
  {
    "id": "R57_120",
    "content": "Format joins and subqueries for clarity, aligning them with related SQL clauses.",
    "project": "NickBwalley_BlogFlow",
    "file": "postgres-sql-style-guide.mdc",
    "first_level": "Code Implementation",
    "second_level": "Code Style Conventions"
  },
  {
    "id": "R57_121",
    "content": "Prefer full table names when referencing tables. This helps for readability.",
    "project": "NickBwalley_BlogFlow",
    "file": "postgres-sql-style-guide.mdc",
    "first_level": "Code Implementation",
    "second_level": "Code Style Conventions"
  },
  {
    "id": "R57_122",
    "content": "Use meaningful aliases that reflect the data or transformation applied, and always include the 'as' keyword for clarity.",
    "project": "NickBwalley_BlogFlow",
    "file": "postgres-sql-style-guide.mdc",
    "first_level": "Code Implementation",
    "second_level": "Code Style Conventions"
  },
  {
    "id": "R57_123",
    "content": "If a query is extremely complex, prefer a CTE.",
