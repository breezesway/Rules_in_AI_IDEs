    "content": "DO NOT AUTOMATE: Never attempt to automate login during exploration phase",
    "project": "nzyoni_super-todo",
    "file": "e2e-best-practices.mdc",
    "first_level": "AI Collaboration Specifications",
    "second_level": "AI Behavior & Decision Strategies"
  },
  {
